# Copy this file to .env on the Oracle server, then fill the values.

# Your domain or subdomain, for example:
# APP_DOMAIN=trade.example.com
APP_DOMAIN=

NODE_ENV=production
PORT=8080

# Telegram public channel
PUBLIC_TELEGRAM_BOT_TOKEN=
PUBLIC_TELEGRAM_CHAT_ID=
PUBLIC_TELEGRAM_INVITE_URL=
PUBLIC_TELEGRAM_BOT_USERNAME=

# Telegram private bot
PRIVATE_TELEGRAM_BOT_TOKEN=
PRIVATE_TELEGRAM_BOT_USERNAME=

# Optional
GLASSNODE_API_KEY=
